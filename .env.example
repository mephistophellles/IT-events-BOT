# ===========================
# Telegram Bot Configuration
# ===========================
# Get your token from @BotFather: https://t.me/BotFather
BOT_TOKEN=7996590267:AAEZUEB-ydqxQYmo8xsoN-x441c-FE7FsG4

# Your Telegram user ID (get it from @userinfobot)
# Multiple admins: comma-separated, e.g. 123456789,987654321
ADMIN_IDS=-1145975030

# ===========================
# AI Classifier (choose one)
# ===========================

# Option 1: Claude API — https://console.anthropic.com
# Recommended: claude-3-5-haiku is fast and cheap (~$0.001 per 1000 events)
USE_CLAUDE_CLASSIFIER=false
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-haiku-20241022

# Option 2: Gemini API — https://aistudio.google.com/app/apikey
USE_GEMINI_CLASSIFIER=true
GEMINI_API_KEY=AIzaSyC5dLGlbQw1uiHf4V3BO7scGQpv68OThz4
GEMINI_MODEL=gemini-2.0-flash

# If both are false, the bot uses the local BART model (~1.5GB) or keyword fallback

# ===========================
# Classifier Settings
# ===========================
# 0.3–0.4 = more events (some false positives)
# 0.5–0.6 = balanced
# 0.7–0.8 = strict filtering
CLASSIFIER_CONFIDENCE_THRESHOLD=0.4

# ===========================
# Monitoring Settings
# ===========================
# How often to check resources for new events (minutes)
CHECK_INTERVAL_MINUTES=60

# ===========================
# Database
# ===========================
# Leave default for SQLite, or set a PostgreSQL URL for production
DATABASE_URL=sqlite:///events_bot.db
